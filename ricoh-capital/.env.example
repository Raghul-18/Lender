# ── SUPABASE ──────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── APP CONFIG ────────────────────────────────────────────
VITE_APP_NAME=Zoro Capital
VITE_APP_URL=http://localhost:5173

# ── EDGE FUNCTIONS (server-side only, NOT VITE_ prefixed) ──
# Used by Supabase Edge Functions — set via: npx supabase secrets set ...
# NEVER put the service role key in VITE_ variables (it would be exposed to the browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (set via CLI secrets, not here)
# SITE_URL=https://your-production-domain.com      (set via CLI secrets)
